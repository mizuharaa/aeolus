# =============================================================================
# Aeolus — Environment Variables Example
# Copy this file to .env and fill in the appropriate values.
# NEVER commit the real .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16 + TimescaleDB)
# -----------------------------------------------------------------------------
# Async URL used by SQLAlchemy / asyncpg (FastAPI, background workers)
DATABASE_URL=postgresql+asyncpg://aeolus:aeolus@localhost:5432/aeolus

# Sync URL used by Alembic migrations and scripts that cannot use async
DATABASE_URL_SYNC=postgresql://aeolus:aeolus@localhost:5432/aeolus

# Individual components (used by docker-compose health checks, etc.)
POSTGRES_USER=aeolus
POSTGRES_PASSWORD=aeolus
POSTGRES_DB=aeolus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Main connection URL (used for caching, pub/sub, rate-limiting)
REDIS_URL=redis://localhost:6379/0

# Separate DB indexes for different concerns (optional)
REDIS_CACHE_DB=0
REDIS_STREAM_DB=1
REDIS_CELERY_DB=2

# -----------------------------------------------------------------------------
# Streaming Backend
# Set STREAM_BACKEND to either "redis_streams" or "kafka"
# -----------------------------------------------------------------------------
STREAM_BACKEND=redis_streams

# Kafka — only required when STREAM_BACKEND=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=aeolus.disruption.events
KAFKA_TOPIC_FLIGHTS=aeolus.flights.updates
KAFKA_CONSUMER_GROUP=aeolus-consumers
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# -----------------------------------------------------------------------------
# Maps — Mapbox GL JS
# -----------------------------------------------------------------------------
# Get a free token at https://account.mapbox.com/
MAPBOX_TOKEN=your_mapbox_token_here

# -----------------------------------------------------------------------------
# Authentication — AWS Cognito
# Leave blank to disable Cognito and use JWT-only auth (development only)
# -----------------------------------------------------------------------------
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1
# JWKS endpoint is derived automatically from the pool ID and region

# JSON Web Token (fallback / internal service auth)
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_PROFILE=default

# If not using instance roles / environment credentials, set key pair:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 — model artifact storage
S3_BUCKET=aeolus-artifacts
S3_MODEL_PREFIX=models/

# SQS (optional async job queue)
SQS_QUEUE_URL=

# -----------------------------------------------------------------------------
# OpenSky Network — real-time ADS-B flight data
# OAuth2 client credentials (preferred, 5-second ADS-B resolution).
# Create an API client at https://opensky-network.org/my-opensky
# Leave blank for anonymous access (10-second resolution, strict rate limits).
#
# IMPORTANT — Railway deployment:
#   Railway's datacenter IPs are blocked by OpenSky. Set OPENSKY_PROXY_BASE
#   on Railway so the backend routes OpenSky requests through the Vercel relay
#   (apps/web/app/api/osky/[action]/route.ts) which OpenSky does allow.
#
#   Railway env vars:
#     OPENSKY_PROXY_BASE=https://your-vercel-url.vercel.app/api/osky
#     OSKY_RELAY_KEY=some-random-secret   # optional shared secret
#
#   Vercel env vars (for the relay to authenticate with OpenSky):
#     OPENSKY_CLIENT_ID=your-client-id
#     OPENSKY_CLIENT_SECRET=your-client-secret
#     OSKY_RELAY_KEY=some-random-secret   # must match Railway value if set
# -----------------------------------------------------------------------------
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Legacy basic-auth (deprecated, no longer used)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# Relay config (set on Railway; points to Vercel /api/osky route)
OPENSKY_PROXY_BASE=
OSKY_RELAY_KEY=

# -----------------------------------------------------------------------------
# Weather Data (aviationweather.gov — no API key required)
# -----------------------------------------------------------------------------
# Polling interval in seconds for METAR / TAF / SIGMET fetches
WEATHER_FETCH_INTERVAL_SECS=300

# Bounding box for weather queries (continental US default)
WEATHER_BBOX_MIN_LAT=24.0
WEATHER_BBOX_MAX_LAT=50.0
WEATHER_BBOX_MIN_LON=-125.0
WEATHER_BBOX_MAX_LON=-66.0

# NOAA / NWS GridPoints API (for grid-based forecasts)
NWS_USER_AGENT=Aeolus/0.1.0 (contact@example.com)

# -----------------------------------------------------------------------------
# Optimizer (OR-Tools MILP + Heuristic Fallback)
# -----------------------------------------------------------------------------
# Maximum wall-clock time (seconds) allowed for the MILP solver per scenario
SOLVER_TIMEOUT_SECS=30

# Fall back to greedy heuristic if MILP exceeds timeout
USE_HEURISTIC_FALLBACK=true

# Number of parallel solver threads (0 = auto-detect CPU cores)
SOLVER_NUM_THREADS=0

# Maximum number of aircraft swaps considered per recovery window
OPTIMIZER_MAX_SWAPS=50

# Crew pairing cost weight relative to delay cost (0.0 – 1.0)
OPTIMIZER_CREW_COST_WEIGHT=0.4

# FAR 117 rest buffer beyond legal minimum (minutes)
FAR117_REST_BUFFER_MINS=30

# -----------------------------------------------------------------------------
# Simulation Engine
# -----------------------------------------------------------------------------
# Seed for reproducible Monte Carlo runs (leave blank for random)
SIM_RANDOM_SEED=

# Default number of Monte Carlo iterations per disruption scenario
SIM_MC_ITERATIONS=1000

# Max concurrent simulation workers
SIM_MAX_WORKERS=4

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
# Environments: development | staging | production

DEBUG=true
LOG_LEVEL=INFO
# Log levels: DEBUG | INFO | WARNING | ERROR | CRITICAL

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
# Increase workers in production (typically 2 * CPU_CORES + 1)

# WebSocket heartbeat interval (seconds)
WS_HEARTBEAT_SECS=30

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=120

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=

# OpenTelemetry collector endpoint (leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Frontend (Next.js) — NEXT_PUBLIC_ vars are embedded at build time
# -----------------------------------------------------------------------------
# REST calls always go through the Next.js server-side proxy route
# (apps/web/app/api/v1/[...path]/route.ts) — they never hit Railway directly
# from the browser, so no CORS is needed on Railway for REST.
#
# WebSocket CANNOT go through the proxy (Vercel doesn't support server-side WS
# relay), so the browser connects directly to Railway. Set at least one of:
#   NEXT_PUBLIC_WS_URL=wss://aeolus-api.up.railway.app   ← explicit (preferred)
#   NEXT_PUBLIC_API_URL=https://aeolus-api.up.railway.app ← derived (https→wss)
# If neither is set, WS falls back to ws://localhost:8000 (broken in prod).
#
# Server-side (non-public) — the proxy target. Set this in Vercel env vars:
#   API_URL=https://aeolus-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Server-side proxy target — read at request time, no redeploy needed.
API_URL=http://localhost:8000
# Server-side WebSocket origin returned by /api/ws-config at request time.
WS_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Feature flags (set to "true" to enable)
NEXT_PUBLIC_FEATURE_LIVE_MAP=true
NEXT_PUBLIC_FEATURE_CREW_VIEW=true
NEXT_PUBLIC_FEATURE_SIMULATOR=true
